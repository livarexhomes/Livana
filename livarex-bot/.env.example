# ── Livarex WhatsApp Bot — Environment Variables ───────────────────────────

# WhatsApp Cloud API (Meta)
# Get these from: developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_TOKEN=EAAxxxxx...              # System User access token
WHATSAPP_PHONE_NUMBER_ID=1234567890    # Phone number ID (not the actual number)
WHATSAPP_VERIFY_TOKEN=livarex_verify_token  # Any string — used to verify the webhook

# Anthropic (Claude AI)
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (your existing project)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...       # Service role key (NOT the anon key)

# Admin notifications
# The WhatsApp number that receives new signup / KYC / agent escalation alerts
# Format: country code + number, no + or spaces (e.g. 2348012345678 for Nigeria)
ADMIN_PHONE_NUMBER=2347061370742

# Optional: extra security for Supabase webhook endpoints
# Set this in Supabase webhook headers as x-webhook-secret
WEBHOOK_SECRET=your_random_secret_here

# Optional: listings API URL (if you have a separate CMS endpoint)
# If not set, listings are fetched from Supabase directly
LISTINGS_API_URL=

PORT=3000
