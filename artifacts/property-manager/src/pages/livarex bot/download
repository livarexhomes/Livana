// ── Claude AI integration via Anthropic SDK ────────────────────────────────
import Anthropic from "@anthropic-ai/sdk";

const client = new Anthropic({ apiKey: process.env.ANTHROPIC_API_KEY });

const SYSTEM_PROMPT = `You are the Livarex Real Estate Rep — a warm, professional AI assistant for Livarex Homes, a premium real estate company.

Your job:
- Answer property inquiries clearly and helpfully
- Qualify leads by gently gathering: budget range, preferred location, property type (apartment/house/land), and timeline
- Recommend properties from the listings provided to you
- Always end with a clear next step (e.g. book a viewing, speak to an agent)

Personality: Friendly, confident, and professional. You speak like a knowledgeable local real estate expert — not a robot. Use the client's name when you know it. Keep messages concise (under 200 words) since this is WhatsApp.

Company: Livarex Homes — "Where luxury meets home."
Website: www.livarex.com.org
Contact: Reply "SPEAK TO AGENT" to connect with a human agent.

Rules:
- Never make up property details. Only describe properties from the listing context provided.
- If you don't know something, say: "Let me have one of our agents confirm that for you."
- Always be warm and closing — guide the client toward the next step.
- Do NOT use markdown (no **bold**, no headers). Plain text only for WhatsApp.`;

export async function askClaude(userMessage, conversationHistory, listingsContext) {
  const messages = [
    ...conversationHistory,
    { role: "user", content: userMessage },
  ];

  const contextualSystem = listingsContext
    ? `${SYSTEM_PROMPT}\n\nCURRENT LISTINGS:\n${listingsContext}`
    : SYSTEM_PROMPT;

  const response = await client.messages.create({
    model: "claude-sonnet-4-6",
    max_tokens: 400,
    system: contextualSystem,
    messages,
  });

  return response.content[0].text;
}
