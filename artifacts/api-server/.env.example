# Resend — get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Sender address (must be from a verified domain in Resend)
FROM_EMAIL=Livana <noreply@livana.ng>

# Supabase — used server-side to generate confirmation links
# Find these in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Frontend origin — used as the redirectTo base in confirmation links
APP_URL=https://your-app.vercel.app

# Port the server listens on
PORT=3000
