{
  "extends": "../../tsconfig.base.json",
  "include": [
    "*.js",
    "*.jsx",
    "*.ts",
    "*.tsx",
    "app/**/*",
    "components/**/*",
    "lib/**/*",
    "pages/**/*",
    "src/**/*",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "out",
    "dist",
    "**/*.test.ts"
  ],
  "compilerOptions": {
    "noEmit": true,
    "jsx": "preserve",
    "lib": [
      "esnext",
      "dom",
      "dom.iterable"
    ],
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "types": [
      "node"
    ],
    "paths": {
      "@/*": [
        "./src/*",
        "./*"
      ]
    },
    "allowJs": true,
    "strict": false,
    "incremental": true,
    "esModuleInterop": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "references": [
    {
      "path": "../../lib/api-client-react"
    }
  ]
}
