{
    "version": 2,
    "builds": [
      {
        "src": "artifacts/property-manager/package.json",
        "use": "@vercel/static-build",
        "config": { "distDir": "vercel-out" }
      }
    ],
    "routes": [
      { "handle": "filesystem" },
      { "src": "/(.*)", "dest": "/index.html" }
    ]
  }
  