{
  "buildCommand": "pnpm --filter @workspace/property-manager run build && pnpm --filter @workspace/property-manager run build:ssr && node scripts/prerender.mjs",
  "outputDirectory": "artifacts/property-manager/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/send-confirmation", "destination": "/api/send-confirmation" },
    { "source": "/api/delete-user", "destination": "/api/delete-user" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
