# Copy this file to artifacts/property-manager/.env.local and fill in your values.
# Never commit .env.local — it is gitignored.

# Supabase project URL (found in: Supabase dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase public anon key (found in: Supabase dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Port the dev server listens on.
# The automations.yaml dev-server service sets this to 3000 automatically.
# Only set manually when running outside the devcontainer.
PORT=3000
